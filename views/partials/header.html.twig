<header class="site-header">
  <div class="header-inner">

    {# ── Logo (always visible) ── #}
    <a href="/" class="header-logo" aria-label="Filmatrix - Inicio">
      <img src="/assets/img/filmatrix_isotipo.webp" alt="Filmatrix">
    </a>

    {# ── Hamburger menu toggle (mobile only) ── #}
    <button class="menu-toggle" type="button" id="menu-toggle"
            aria-label="Abrir menú" aria-expanded="false" aria-controls="main-menu">
      <span></span>
      <span></span>
      <span></span>
    </button>

    {# ── Main navigation (hidden on mobile, visible on desktop) ── #}
    <nav class="nav-menu" id="main-menu" aria-label="Navegación principal">
      <a href="/titles" class="nav-menu-item">Películas</a>

      {% if app.user_logged_in %}
        <a href="/profile" class="nav-menu-item">Mi Perfil</a>
        <a href="/my-reviews" class="nav-menu-item">Mis Reseñas</a>
        <a href="/my-watchlist" class="nav-menu-item">Mi Watchlist</a>
        <form action="/logout" method="POST" class="nav-menu-form">
          <input type="hidden" name="csrf_token" value="{{ csrf_token }}">
          <button type="submit" class="nav-menu-item nav-menu-item--logout">Cerrar Sesión</button>
        </form>
      {% else %}
        <a href="/login" class="nav-menu-item">Iniciar Sesión</a>
        <a href="/register" class="nav-menu-item">Registrarme</a>
      {% endif %}
    </nav>

    {# ── Search toggle button (mobile only) ── #}
    <button type="button" class="search-toggle" aria-label="Mostrar barra de búsqueda" aria-expanded="false">
      <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <circle cx="11" cy="11" r="8"></circle>
        <line x1="21" y1="21" x2="16.65" y2="16.65"></line>
      </svg>
    </button>

    {# ── Search form (slide-down on mobile, inline on desktop) ── #}
    <form class="search-form" role="search" action="/titles/search" method="GET">
      <div class="search-input-group">
        <input type="search" class="search-input" name="q" placeholder="Buscar..." aria-label="Buscar en el sitio">
        <button type="submit" class="search-submit" aria-label="Ejecutar búsqueda">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <circle cx="11" cy="11" r="8"></circle>
            <line x1="21" y1="21" x2="16.65" y2="16.65"></line>
          </svg>
        </button>
      </div>
    </form>

  </div>
</header>
