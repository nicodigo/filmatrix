{% extends 'layout/main.html.twig' %}

{% block title %}Cambiar Contraseña — Filmatrix{% endblock %}
{% block robots %}noindex, nofollow{% endblock %}

{% block styles %}
  <link rel="stylesheet" href="/assets/css/editar_perfil.css">
{% endblock %}

{% block main_class %}ep-main{% endblock %}

{% block content %}
  <div class="ep-header">
    <a href="/profile" class="ep-back">Volver al perfil</a>
    <h1 class="ep-title">Cambiar Contraseña</h1>
  </div>

  {% if error %}
    <div class="auth-alert ep-alert" role="alert">
      {{ error }}
    </div>
  {% endif %}

  {% if success %}
    <div class="ep-success" role="status">
      {{ success }}
    </div>
  {% endif %}

  <form class="ep-form" method="POST" action="/profile/password">
    <input type="hidden" name="csrf_token" value="{{ csrf_token }}">

    <section class="ep-section">
      <h2 class="ep-section__title">Cambiar contraseña</h2>

      <div class="ep-fields">

        <div class="auth-field">
          <label class="auth-label">Contraseña actual</label>
          <input class="auth-input"
                 type="password"
                 name="current_password">
        </div>

      </div>

      <div class="ep-fields">

        <div class="auth-field">
          <label class="auth-label">Nueva contraseña</label>
          <input class="auth-input"
                 type="password"
                 name="new_password">
        </div>

        <div class="auth-field">
          <label class="auth-label">Repetir nueva contraseña</label>
          <input class="auth-input"
                 type="password"
                 name="confirm_password">
        </div>

      </div>
    </section>

    <div class="ep-actions">
      <a href="/profile" class="ep-btn ep-btn--ghost">Cancelar</a>
      <button type="submit" class="ep-btn ep-btn--primary">Guardar cambios</button>
    </div>

  </form>
{% endblock %}
