{% extends 'layout/main.html.twig' %}

{% block title %}Mis Listas — Filmatrix{% endblock %}

{% block description %}Creá y gestioná tus listas de películas en Filmatrix.{% endblock %}

{% block styles %}
  <link rel="stylesheet" href="/assets/css/lists.css">
{% endblock %}

{% block content %}
  <header class="lists-header">
    <h1 class="lists-title">Mis Listas</h1>
    <button type="button" class="lists-create-btn" id="lists-create-btn" aria-haspopup="dialog">
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" aria-hidden="true">
        <line x1="12" y1="5" x2="12" y2="19"></line>
        <line x1="5" y1="12" x2="19" y2="12"></line>
      </svg>
      Nueva lista
    </button>
  </header>

  {% if lists is empty %}
    <section class="lists-empty" aria-label="Sin listas">
      <p>No tenés listas todavía.</p>
      <p>Creá una para organizar tus películas.</p>
    </section>
  {% else %}
    <section class="lists-grid" aria-label="Tus listas">
      {% for list in lists %}
        <article class="list-card">
          <a href="/my-lists/detail?id={{ list.id }}" class="list-card__link" aria-label="Ver lista: {{ list.name }}">
            <header class="list-card__header">
              <h2 class="list-card__name">{{ list.name }}</h2>
              <span class="list-card__badge {{ list.isPublic ? 'list-card__badge--public' : 'list-card__badge--private' }}">
                {{ list.isPublic ? 'Pública' : 'Privada' }}
              </span>
            </header>
            <dl class="list-card__meta">
              <div class="list-card__meta-item">
                <dt>Películas</dt>
                <dd>{{ list.itemCount }}</dd>
              </div>
              <div class="list-card__meta-item">
                <dt>Actualizada</dt>
                <dd><time datetime="{{ list.updatedAt }}">{{ list.updatedAt|slice(0, 10) }}</time></dd>
              </div>
            </dl>
          </a>
          <button type="button"
                  class="list-card__delete-btn"
                  data-list-id="{{ list.id }}"
                  data-list-name="{{ list.name }}"
                  aria-label="Eliminar lista {{ list.name }}"
                  title="Eliminar lista">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true">
              <polyline points="3 6 5 6 21 6"></polyline>
              <path d="M19 6l-1 14a2 2 0 0 1-2 2H8a2 2 0 0 1-2-2L5 6"></path>
              <line x1="10" y1="11" x2="10" y2="17"></line>
              <line x1="14" y1="11" x2="14" y2="17"></line>
            </svg>
          </button>
        </article>
      {% endfor %}
    </section>
  {% endif %}

  {# ── Create list dialog ── #}
  <dialog class="list-dialog" id="list-create-dialog" aria-labelledby="list-dialog-title">
    <form method="dialog" class="list-dialog__form" id="list-create-form">
      <header class="list-dialog__header">
        <h2 id="list-dialog-title" class="list-dialog__title">Nueva lista</h2>
        <button type="button" class="list-dialog__close" id="list-dialog-close" aria-label="Cerrar">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true">
            <line x1="18" y1="6" x2="6" y2="18"></line>
            <line x1="6" y1="6" x2="18" y2="18"></line>
          </svg>
        </button>
      </header>

      <label class="list-dialog__label" for="list-name-input">Nombre</label>
      <input type="text"
             id="list-name-input"
             name="name"
             class="list-dialog__input"
             placeholder="ej. Clásicos de los 90"
             maxlength="150"
             required
             autofocus>

      <label class="list-dialog__checkbox">
        <input type="checkbox" name="is_public" id="list-public-checkbox" checked>
        <span class="list-dialog__checkbox-label">Lista pública</span>
        <span class="list-dialog__checkbox-hint">(visible para todos)</span>
      </label>

      <footer class="list-dialog__actions">
        <button type="button" class="list-dialog__btn list-dialog__btn--secondary" id="list-dialog-cancel">Cancelar</button>
        <button type="submit" class="list-dialog__btn list-dialog__btn--primary">Crear lista</button>
      </footer>
    </form>
  </dialog>

{% endblock %}

{% block scripts %}
  <script src="/assets/js/modules/ListActions.js" type="module"></script>
{% endblock %}
