{% extends 'layout/main.html.twig' %}

{% block title %}Error interno — Filmatrix{% endblock %}

{% block description %}Ocurrió un error inesperado en Filmatrix.{% endblock %}

{% block content %}
<section class="error-section">
  <div class="error-card">
    <h1 class="error-code">500</h1>
    <h2 class="error-title">Error interno del servidor</h2>
    <p class="error-text">
      Algo salió mal. Nuestro equipo fue notificado.
      Por favor intentá de nuevo más tarde.
    </p>
    <a href="/" class="error-link">Volver al inicio</a>
  </div>
</section>
{% endblock %}
