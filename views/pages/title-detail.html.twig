{% extends 'layout/main.html.twig' %}

{% block title %}{{ title.title }} ({{ title.releaseYear|default('S/D') }}) — Filmatrix{% endblock %}

{% block description %}{{ title.synopsis|default('Información, reparto y reseñas de la película en Filmatrix.')|slice(0, 160) }}{% endblock %}

{% block og_type %}video.movie{% endblock %}

{% block og_image %}{{ title.posterUrl|default('/assets/img/hero-bg.webp') }}{% endblock %}

{% block canonical %}{{ app_url }}/titles/detail?{{ {'tmdb_id': tmdbId}|url_encode }}{% endblock %}

{% block styles %}
  <link rel="stylesheet" href="/assets/css/title-card.css">
  <link rel="stylesheet" href="/assets/css/title-detail.css">
  <link rel="stylesheet" href="/assets/css/lists.css">
{% endblock %}

{% block main_class %}detalle-main{% endblock %}

{% block content %}
  <script type="application/ld+json">{{ movieJsonLd|raw }}</script>
  <section class="detalle-hero">
    <div class="detalle-hero__poster-wrap">
      <img
        class="detalle-hero__poster"
        src="{{ title.posterUrl|default('/assets/img/hero-bg.webp') }}"
        alt="Portada de {{ title.title }}">
    </div>
    <div class="detalle-hero__info">
      <h1 class="detalle-titulo">{{ title.title }}</h1>
      <div class="detalle-meta">
        <span class="detalle-meta__item">{{ title.releaseYear|default('S/D') }}</span>
        <span class="detalle-meta__sep">·</span>
        <span class="detalle-meta__item">{{ duration|default('S/D') }}</span>
        <span class="detalle-meta__sep">·</span>
        <span class="detalle-meta__item">{{ genreLabel|default('S/D') }}</span>
      </div>
      {% if app.user_logged_in %}
        <div class="detalle-watchlist" id="watchlistSection" data-title-id="{{ title.id }}">

          <div id="watchlistAddState" {% if watchlistItem %}hidden{% endif %}>
            <button class="detalle-watchlist__add-btn" id="watchlistAdd" type="button">
              Agregar a watchlist
            </button>
          </div>

          <div id="watchlistInState" {% if not watchlistItem %}hidden{% endif %}>
            <select class="detalle-watchlist__status-select" id="watchlistStatus">
              <option value="pending" {% if watchlistItem and watchlistItem.status == 'pending' %}selected{% endif %}>
                Pendiente
              </option>
              {% if not isUpcoming %}
                <option value="watched" {% if watchlistItem and watchlistItem.status == 'watched' %}selected{% endif %}>
                  Vista
                </option>
              {% endif %}
            </select>
            <button class="detalle-watchlist__remove-btn" id="watchlistRemove" type="button">
              Eliminar de watchlist
            </button>
          </div>

        </div>

        {# ── List section ── #}
        {% if not isUpcoming %}
          <div class="detalle-lists" id="listsSection" data-title-id="{{ title.id }}">
            <button class="detalle-lists__btn" id="listsAddBtn" type="button">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true">
                <line x1="8" y1="6" x2="21" y2="6"></line>
                <line x1="8" y1="12" x2="21" y2="12"></line>
                <line x1="8" y1="18" x2="21" y2="18"></line>
                <line x1="3" y1="6" x2="3.01" y2="6"></line>
                <line x1="3" y1="12" x2="3.01" y2="12"></line>
                <line x1="3" y1="18" x2="3.01" y2="18"></line>
              </svg>
              Agregar a lista
            </button>

            <dialog class="list-dialog" id="listsDialog" aria-labelledby="lists-dialog-title">
              <form method="dialog" class="list-dialog__form" id="lists-form">
                <header class="list-dialog__header">
                  <h2 id="lists-dialog-title" class="list-dialog__title">Agregar a lista</h2>
                  <button type="button" class="list-dialog__close" id="lists-dialog-close" aria-label="Cerrar">
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true">
                      <line x1="18" y1="6" x2="6" y2="18"></line>
                      <line x1="6" y1="6" x2="18" y2="18"></line>
                    </svg>
                  </button>
                </header>

                <div class="list-dialog__list-group" id="lists-checklist">
                  <p class="list-dialog__loading">Cargando listas…</p>
                </div>

                <footer class="list-dialog__actions">
                  <button type="button" class="list-dialog__btn list-dialog__btn--secondary" id="lists-dialog-cancel">Cerrar</button>
                </footer>
              </form>
            </dialog>
          </div>
        {% endif %}
      {% endif %}
    </div>
  </section>

  <section class="detalle-info-section">
    <div class="detalle-info-grid">
      <div class="detalle-sinopsis">
        <h2 class="detalle-section-label">Sinopsis</h2>
        <p class="detalle-sinopsis__texto">{{ title.synopsis|default('Sin sinopsis disponible.') }}</p>
      </div>
      <div class="detalle-datos">
        <div class="detalle-dato">
          <span class="detalle-dato__label">{{ isUpcoming ? 'Estreno' : 'Valoración' }}</span>
          {% if isUpcoming %}
            <span class="detalle-dato__val">{{ title.releaseDate|date('d/m/Y') }}</span>
          {% else %}
            <div class="detalle-dato__rating">
              <svg class="detalle-dato__star" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z" />
              </svg>
              <span class="detalle-dato__val">{{ title.avgScore|default('S/P') }}</span>
              <span class="detalle-dato__max">/ 5</span>
            </div>
          {% endif %}
        </div>
        <div class="detalle-dato">
          <span class="detalle-dato__label">Género</span>
          <span class="detalle-dato__badge">{{ genreLabel|default('S/D') }}</span>
        </div>
        <div class="detalle-dato">
          <span class="detalle-dato__label">Año</span>
          <span class="detalle-dato__val">{{ title.releaseYear|default('S/D') }}</span>
        </div>
        <div class="detalle-dato">
          <span class="detalle-dato__label">Duración</span>
          <span class="detalle-dato__val">{{ duration|default('S/D') }}</span>
        </div>
        <div class="detalle-dato">
          <span class="detalle-dato__label">Idioma original</span>
          <span class="detalle-dato__val">{{ title.language|upper|default('S/D') }}</span>
        </div>
      </div>
    </div>
  </section>

  <section class="detalle-reparto-section">
    <h2 class="detalle-section-label">Reparto</h2>
    <div class="reparto-grid">
      {% if cast is empty %}
        <p class="detalle-empty">Sin información de reparto.</p>
      {% else %}
        {% for actor in cast %}
          <div class="reparto-card">
            <span class="reparto-card__nombre">{{ actor.name }}</span>
            <span class="reparto-card__rol">{{ actor.character_name|default(actor.role) }}</span>
          </div>
        {% endfor %}
      {% endif %}
    </div>
  </section>

  <section class="detalle-nueva-resenia-section">
    {% if isUpcoming %}
      <p class="detalle-empty">Todavía no se estrenó. Vas a poder dejar tu reseña cuando salga.</p>
    {% elseif app.user_logged_in %}
      {% if userReview %}

        <div class="resena-propia" id="resenaPropia">
          <div class="resena-propia__header">
            <span class="resena-propia__label">Tu reseña</span>
            <div class="resena-propia__actions">
              <button class="btn-editar-resenia" id="btnEditarResena">
                <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24"
                  fill="none" stroke="currentColor" stroke-width="2"
                  stroke-linecap="round" stroke-linejoin="round">
                  <path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/>
                  <path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/>
                </svg>
                Editar
              </button>
              <form action="/review/delete" method="POST" class="resena-delete-form">
                <input type="hidden" name="csrf_token" value="{{ csrf_token }}">
                <input type="hidden" name="review_id" value="{{ userReview.id }}">
                <input type="hidden" name="tmdb_id" value="{{ tmdbId }}">
                <button type="button" class="btn-eliminar-resenia">
                  <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24"
                    fill="none" stroke="currentColor" stroke-width="2"
                    stroke-linecap="round" stroke-linejoin="round">
                    <polyline points="3 6 5 6 21 6"/>
                    <path d="M19 6l-1 14a2 2 0 0 1-2 2H8a2 2 0 0 1-2-2L5 6"/>
                    <path d="M10 11v6M14 11v6"/>
                    <path d="M9 6V4a1 1 0 0 1 1-1h4a1 1 0 0 1 1 1v2"/>
                  </svg>
                  Eliminar
                </button>
              </form>
            </div>
          </div>
          <div class="resena-propia__estrellas">
            {% for i in 1..5 %}
              <span class="resenia-card__star {{ i <= userReview.score ? 'resenia-card__star--filled' : '' }}">★</span>
            {% endfor %}
          </div>
          <p class="resena-propia__texto">{{ userReview.body|default('Sin comentario.') }}</p>
        </div>

        <div class="resena-form-wrap" id="editarResenaWrap">
          <form class="resena-form" action="/review/update" method="POST">
            <input type="hidden" name="csrf_token" value="{{ csrf_token }}">
            <input type="hidden" name="review_id" value="{{ userReview.id }}">
            <input type="hidden" name="tmdb_id" value="{{ tmdbId }}">
            <div class="resena-form__stars" role="group" aria-label="Puntuación">
              {% for i in range(5, 1) %}
                <input type="radio" id="editStar{{ i }}" name="score" value="{{ i }}"
                  class="star-input" {{ userReview.score == i ? 'checked' : '' }}>
                <label for="editStar{{ i }}" class="star-label" aria-label="{{ i }} estrellas">★</label>
              {% endfor %}
            </div>
            <textarea
              class="resena-form__textarea"
              name="review_body"
              rows="5"
              maxlength="1000">{{ userReview.body|default('') }}</textarea>
            <div class="resena-form__actions">
              <button type="button" class="btn-cancelar" id="btnCancelarEdicion">Cancelar</button>
              <button type="submit" class="btn-publicar">Guardar cambios</button>
            </div>
          </form>
        </div>

      {% else %}

        <input type="checkbox" id="resenaToggle" class="resena-toggle-input">
        <label for="resenaToggle" class="btn-crear-resenia">
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24"
            fill="none" stroke="currentColor" stroke-width="2"
            stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M12 20h9" />
            <path d="M16.5 3.5a2.121 2.121 0 0 1 3 3L7 19l-4 1 1-4L16.5 3.5z" />
          </svg>
          Escribir reseña
        </label>
        <div class="resena-form-wrap">
          <form class="resena-form" action="/review/post" method="POST">
            <input type="hidden" name="csrf_token" value="{{ csrf_token }}">
            <input type="hidden" name="title_id" value="{{ title.id }}">
            <input type="hidden" name="tmdb_id" value="{{ tmdbId }}">
            <div class="resena-form__stars" role="group" aria-label="Puntuación">
              {% for i in range(5, 1) %}
                <input type="radio" id="star{{ i }}" name="score" value="{{ i }}" class="star-input">
                <label for="star{{ i }}" class="star-label" aria-label="{{ i }} estrellas">★</label>
              {% endfor %}
            </div>
            <textarea
              class="resena-form__textarea"
              name="review_body"
              placeholder="Contá qué te pareció la película…"
              rows="5"
              maxlength="1000"></textarea>
            <div class="resena-form__actions">
              <label for="resenaToggle" class="btn-cancelar">Cancelar</label>
              <button type="submit" class="btn-publicar">Publicar reseña</button>
            </div>
          </form>
        </div>

      {% endif %}
    {% endif %}
  </section>

  <section class="detalle-bottom-section">
    <div class="resenias-col">
      <h2 class="detalle-section-label">Reseñas</h2>
      {% if reviews is empty %}
        <p class="detalle-empty">Todavía no hay reseñas.</p>
      {% else %}
        {% for review in reviews %}
          <article class="resenia-card">
            <header class="resenia-card__header">
              <img
                class="resenia-card__avatar"
                src="/assets/img/hero-bg.webp"
                alt="Avatar de {{ review.username }}">
              <div class="resenia-card__meta">
                <span class="resenia-card__usuario">{{ review.username }}</span>
                <div class="resenia-card__estrellas" aria-label="{{ review.score|round }} estrellas">
                  {% for i in 1..5 %}
                    <span class="resenia-card__star {{ i <= review.score|round(0) ? 'resenia-card__star--filled' : '' }}">★</span>
                  {% endfor %}
                </div>
              </div>
              <time class="resenia-card__fecha">{{ review.created_at|date('d M Y') }}</time>
            </header>
            <p class="resenia-card__texto">{{ review.body|default('') }}</p>
          </article>
        {% endfor %}
      {% endif %}
    </div>

    <aside class="sugeridas-col">
      <h2 class="detalle-section-label">Tal vez te interese</h2>
      <div class="sugeridas-lista">
        {% for sug in suggested %}
          <a href="/titles/detail?tmdb_id={{ sug.tmdb_id }}" class="sugerida-item">
            <img
              class="sugerida-item__poster"
              src="{{ sug.poster_url|default('/assets/img/hero-bg.webp') }}"
              alt="Portada de {{ sug.title }}">
            <span class="sugerida-item__titulo">{{ sug.title }}</span>
          </a>
        {% endfor %}
      </div>
    </aside>
  </section>

  {% if userReview %}
    <div class="modal-overlay" id="modalEliminar">
      <div class="modal">
        <p class="modal__texto">¿Seguro que querés eliminar tu reseña?</p>
        <div class="modal__actions">
          <button class="btn-cancelar" id="modalCancelar">Cancelar</button>
          <button class="btn-eliminar-resenia" id="modalConfirmar">Sí, eliminar</button>
        </div>
      </div>
    </div>
  {% endif %}

  {% if flashSuccess %}
    <div class="toast toast--success" id="toast" role="alert">
      <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24"
           fill="none" stroke="currentColor" stroke-width="2"
           stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/>
        <polyline points="22 4 12 14.01 9 11.01"/>
      </svg>
      {{ flashSuccess }}
    </div>
  {% endif %}

  {% if flashError %}
    <div class="toast toast--error" id="toast" role="alert">
      <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24"
           fill="none" stroke="currentColor" stroke-width="2"
           stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <circle cx="12" cy="12" r="10"/>
        <line x1="12" y1="8" x2="12" y2="12"/>
        <line x1="12" y1="16" x2="12.01" y2="16"/>
      </svg>
      {{ flashError }}
    </div>
  {% endif %}

{% endblock %}

{% block scripts %}
  <script type="module" src="/assets/js/pages/TitleDetails.js"></script>
{% endblock %}