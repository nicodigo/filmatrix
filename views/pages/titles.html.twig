{% extends 'layout/main.html.twig' %}

{% block title %}{% if search_query %}Resultados para "{{ search_query }}" — Filmatrix{% else %}Catálogo — Filmatrix{% endif %}{% endblock %}

{% block description %}Explorá el catálogo completo de películas en Filmatrix.{% endblock %}

{% block styles %}
  <link rel="stylesheet" href="/assets/css/title-card.css">
  <link rel="stylesheet" href="/assets/css/titles.css">
{% endblock %}

{% block content %}
  {% if not search_query and titlesJsonLd %}
    <script type="application/ld+json">{{ titlesJsonLd|raw }}</script>
  {% endif %}
  <input type="checkbox" id="filterToggle" class="filter-toggle-input">
  <section class="films-header">
    <h1 class="films-title">
      {% if search_query %}
        Resultados para <em>"{{ search_query }}"</em>
      {% else %}
        Catálogo
      {% endif %}
    </h1>
    {% if not search_query %}
      <label for="filterToggle" class="films-filter-btn">
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24"
             fill="none" stroke="currentColor" stroke-width="2"
             stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <line x1="4" y1="6" x2="20" y2="6"/>
          <line x1="8" y1="12" x2="16" y2="12"/>
          <line x1="11" y1="18" x2="13" y2="18"/>
        </svg>
        Filtros
      </label>
    {% endif %}
  </section>

  {% if not search_query %}
    <aside class="filter-panel">
      <div class="filter-panel__inner">
        <div class="filter-group">
          <label class="filter-label" for="filterGenre">Género</label>
          <select class="filter-select" id="filterGenre" name="genre">
            <option value="">Todos</option>
            {% for genre in genres %}
              <option value="{{ genre.id }}"
                {% if active_filters.genre == genre.id %}selected{% endif %}>
                {{ genre.name }}
              </option>
            {% endfor %}
          </select>
        </div>
        <div class="filter-group">
          <label class="filter-label" for="filterYear">Año</label>
          <select class="filter-select" id="filterYear" name="year">
            <option value="">Todos</option>
            {% for y in range("now"|date("Y"), 1970) %}
              <option value="{{ y }}"
                {% if active_filters.year == y %}selected{% endif %}>
                {{ y }}
              </option>
            {% endfor %}
          </select>
        </div>
        <div class="filter-group">
          <label class="filter-label" for="filterLanguage">Idioma</label>
          <select class="filter-select" id="filterLanguage" name="language">
            <option value="">Todos</option>
            <option value="es" {% if active_filters.language == 'es' %}selected{% endif %}>Español</option>
            <option value="en" {% if active_filters.language == 'en' %}selected{% endif %}>Inglés</option>
            <option value="fr" {% if active_filters.language == 'fr' %}selected{% endif %}>Francés</option>
            <option value="ja" {% if active_filters.language == 'ja' %}selected{% endif %}>Japonés</option>
            <option value="ko" {% if active_filters.language == 'ko' %}selected{% endif %}>Coreano</option>
          </select>
        </div>
        <div class="filter-group">
          <label class="filter-label" for="filterScore">Puntaje mínimo</label>
          <select class="filter-select" id="filterScore" name="score">
            <option value="">Cualquiera</option>
            <option value="4.5" {% if active_filters.score == 4.5 %}selected{% endif %}>★ 4.5+</option>
            <option value="4"   {% if active_filters.score == 4.0 %}selected{% endif %}>★ 4.0+</option>
            <option value="3"   {% if active_filters.score == 3.0 %}selected{% endif %}>★ 3.0+</option>
          </select>
        </div>
        <div class="filter-group">
          <label class="filter-label" for="filterSort">Ordenar por</label>
          <select class="filter-select" id="filterSort" name="sort">
            {% if app.user_logged_in %}
            <option value="for_you"      {% if active_filters.sort == 'for_you' %}selected{% endif %}>Para vos</option>
            {% endif %}
            <option value="release_year" {% if active_filters.sort == 'release_year' %}selected{% endif %}>Más nuevos</option>
            <option value="popularity"   {% if active_filters.sort == 'popularity' %}selected{% endif %}>Más populares</option>
            <option value="avg_score"    {% if active_filters.sort == 'avg_score' %}selected{% endif %}>Mejor puntuados</option>
          </select>
        </div>
      </div>
    </aside>
  {% endif %}

  <section class="films-section">
    {% if search_query %}
      <p class="films-search-meta">
        {{ titles|length }} resultado{% if titles|length != 1 %}s{% endif %}
      </p>
    {% endif %}

    <div class="films-grid">
      {% if titles is empty %}
        <p class="films-empty">
          {% if search_query %}
            No se encontraron títulos para <strong>"{{ search_query }}"</strong>.
            <a href="/titles">Ver catálogo completo</a>
          {% else %}
            Sin títulos disponibles.
          {% endif %}
        </p>
      {% endif %}

      {% import 'macros/title-cards.html.twig' as cards %}

      {% for movie in titles %}
        {{ cards.titleCard(movie) }}
      {% endfor %}
    </div>
  </section>

  <nav class="page-nav">
      {% if prevUrl %}
          <a href="{{ prevUrl }}" class="btn-page">
              Anterior
          </a>
      {% else %}
          <span class="btn-page disabled">
              Anterior
          </span>
      {% endif %}

      {% if nextUrl %}
          <a href="{{ nextUrl }}" class="btn-page">
              Siguiente
          </a>
      {% else %}
          <span class="btn-page disabled">
              Siguiente
          </span>
      {% endif %}
  </nav>
{% endblock %}
{% block scripts %}
  <script type="module" src="/assets/js/pages/Titles.js"></script>
{% endblock %}
