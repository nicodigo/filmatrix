{% extends 'layout/main.html.twig' %}

{% block title %}Panel de administración — Filmatrix{% endblock %}
{% block robots %}noindex, nofollow{% endblock %}

{% block styles %}
  <link rel="stylesheet" href="/assets/css/admin-reviews.css">
{% endblock %}

{% block main_class %}admin-main{% endblock %}

{% block content %}
  <h1>Reseñas reportadas</h1>

  <div class="admin-header">
    <span class="admin-header__count">{{ flaggedReviews|length }} reporte{{ flaggedReviews|length != 1 ? 's' : '' }}</span>
  </div>

  {% if flaggedReviews is empty %}
    <div class="admin-empty">
      <div class="admin-empty__icon">
        <svg xmlns="http://www.w3.org/2000/svg" width="40" height="40" viewBox="0 0 24 24"
             fill="none" stroke="currentColor" stroke-width="1.5"
             stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <circle cx="11" cy="11" r="8"/>
          <line x1="21" y1="21" x2="16.65" y2="16.65"/>
        </svg>
      </div>
      <p class="admin-empty__text">No hay reseñas reportadas por el momento.</p>
    </div>
  {% else %}
    {% for review in flaggedReviews %}
      <article class="admin-review-card">
        <div class="admin-review-card__header">
          <div class="admin-review-card__meta">
            <span class="admin-review-card__user">{{ review.username }}</span>
            <a href="/titles/detail?tmdb_id={{ review.tmdb_id }}" class="admin-review-card__title">
              {{ review.title }}
            </a>
          </div>

          <div style="display:flex;align-items:center;gap:12px;flex-shrink:0;">
            <div class="admin-review-card__stars" aria-label="Puntuación: {{ review.score }} de 5">
              {% for i in 1..5 %}
                <span class="admin-review-card__star{{ i > review.score|round(0) ? ' admin-review-card__star--empty' : '' }}">&#9733;</span>
              {% endfor %}
            </div>

            <span class="admin-badge {{ review.is_visible ? 'admin-badge--visible' : 'admin-badge--hidden' }}">
              {{ review.is_visible ? 'Visible' : 'Oculta' }}
            </span>
          </div>
        </div>

        <div class="admin-review-card__body{{ review.body is empty ? ' admin-review-card__body--empty' : '' }}">
          {{ review.body|default('Sin texto en la reseña.') }}
        </div>

        <div class="admin-review-card__actions">
          <form action="/admin/reviews/unflag" method="POST" style="display:contents;">
            <input type="hidden" name="csrf_token" value="{{ csrf_token }}">
            <input type="hidden" name="review_id" value="{{ review.id }}">
            <button type="submit" class="admin-btn admin-btn--ghost">Descartar reporte</button>
          </form>

          {% if review.is_visible %}
            <form action="/admin/reviews/hide" method="POST" style="display:contents;">
              <input type="hidden" name="csrf_token" value="{{ csrf_token }}">
              <input type="hidden" name="review_id" value="{{ review.id }}">
              <button type="submit" class="admin-btn admin-btn--danger">Ocultar reseña</button>
            </form>
          {% else %}
            <form action="/admin/reviews/show" method="POST" style="display:contents;">
              <input type="hidden" name="csrf_token" value="{{ csrf_token }}">
              <input type="hidden" name="review_id" value="{{ review.id }}">
              <button type="submit" class="admin-btn admin-btn--restore">Restaurar visibilidad</button>
            </form>
          {% endif %}

          <form action="/admin/reviews/delete" method="POST" style="display:contents;">
            <input type="hidden" name="csrf_token" value="{{ csrf_token }}">
            <input type="hidden" name="review_id" value="{{ review.id }}">
            <button type="submit" class="admin-btn admin-btn--danger">Eliminar</button>
          </form>
        </div>
      </article>
    {% endfor %}
  {% endif %}

  {% if flashSuccess %}
    <div class="toast toast--success toast--visible" id="toast" role="alert">
      <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24"
           fill="none" stroke="currentColor" stroke-width="2"
           stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/>
        <polyline points="22 4 12 14.01 9 11.01"/>
      </svg>
      {{ flashSuccess }}
    </div>
  {% endif %}

  {% if flashError %}
    <div class="toast toast--error toast--visible" id="toast" role="alert">
      <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24"
           fill="none" stroke="currentColor" stroke-width="2"
           stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <circle cx="12" cy="12" r="10"/>
        <line x1="12" y1="8" x2="12" y2="12"/>
        <line x1="12" y1="16" x2="12.01" y2="16"/>
      </svg>
      {{ flashError }}
    </div>
  {% endif %}
{% endblock %}
