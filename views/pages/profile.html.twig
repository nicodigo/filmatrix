{% extends 'layout/main.html.twig' %}

{% block title %}Mi perfil — Filmatrix{% endblock %}

{% block styles %}
  <link rel="stylesheet" href="/assets/css/miPerfil.css">
{% endblock %}

{% block main_class %}perfil-main{% endblock %}

{% block content %}
  <section class="perfil-hero">
    <div class="perfil-avatar-wrap">
      <img class="perfil-avatar" src="/assets/img/user_avatar.png" alt="Avatar de {{ user.username }}">
    </div>

    <div class="perfil-hero__info">
      <h1 class="perfil-nombre">{{ user.username }}</h1>
      <p class="perfil-miembro">Miembro desde {{ user.createdAt|date('F Y') }}</p>
    </div>
  </section>

  <section class="perfil-stats">
    <div class="perfil-stat">
      <span class="perfil-stat__label">Reseñas</span>
      <span class="perfil-stat__num">{{ stats.total_reviews }}</span>
    </div>

    <div class="perfil-stat">
      <span class="perfil-stat__label">Horas vistas</span>
      <span class="perfil-stat__num">{{ stats.total_hours }}</span>
    </div>

    {% if stats.top_genres is not empty %}
    <div class="perfil-stat">
      <span class="perfil-stat__label">Géneros favoritos</span>
      <div class="perfil-stat__genres">
        {% for genre in stats.top_genres %}
          <span class="perfil-stat__genre-badge">{{ genre }}</span>
        {% endfor %}
      </div>
    </div>
    {% endif %}
  </section>

  <section class="perfil-acciones">
    <a href="/profile/edit" class="perfil-btn perfil-btn--primary">Editar perfil</a>
    <a href="/profile/password" class="perfil-btn perfil-btn--primary">Cambiar Contraseña</a>

    <form action="/logout" method="POST">
      <input type="hidden" name="csrf_token" value="{{ csrf_token }}">
      <button type="submit" class="perfil-btn perfil-btn--danger">Cerrar sesión</button>
    </form>
  </section>
{% endblock %}
