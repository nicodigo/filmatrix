{% extends 'layout/main.html.twig' %}

{% block title %}Mis reseñas — Filmatrix{% endblock %}
{% block robots %}noindex, nofollow{% endblock %}

{% block styles %}
  <link rel="stylesheet" href="/assets/css/misResenas.css">
  <link rel="stylesheet" href="/assets/css/title-detail.css">
{% endblock %}

{% block main_class %}perfil-main{% endblock %}

{% block content %}

  <section class="perfil-hero">
    <div class="perfil-hero__info">
      <h1 class="perfil-nombre">Mis reseñas</h1>
      <p class="perfil-miembro">{{ reviews|length }} reseña{{ reviews|length != 1 ? 's' : '' }} publicada{{ reviews|length != 1 ? 's' : '' }}</p>
    </div>
  </section>

  <section class="perfil-resenias">
    {% if reviews is empty %}
      <p class="detalle-empty">Todavía no escribiste ninguna reseña. <a href="/titles" style="color:var(--accent)">Explorá el catálogo</a>.</p>
    {% else %}
      {% for review in reviews %}
        <article class="resenia-card perfil-resenia-card" id="resenaCard{{ review.id }}">

          <a href="/titles/detail?tmdb_id={{ review.tmdb_id }}" class="perfil-resenia__pelicula">
            <img
              class="perfil-resenia__poster"
              src="{{ review.poster_url|default('/assets/img/hero-bg.webp') }}"
              alt="{{ review.title }}">
            <span class="perfil-resenia__titulo">{{ review.title }}</span>
          </a>

          <div class="resena-propia" id="resenaPropia{{ review.id }}">
            <div class="resena-propia__header">
              <div class="resenia-card__estrellas">
                {% for i in 1..5 %}
                  <span class="resenia-card__star {{ i <= review.score|round(0) ? 'resenia-card__star--filled' : '' }}">★</span>
                {% endfor %}
              </div>
              <div class="resena-propia__actions">
                <button class="btn-editar-resenia" data-id="{{ review.id }}">
                  <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24"
                    fill="none" stroke="currentColor" stroke-width="2"
                    stroke-linecap="round" stroke-linejoin="round">
                    <path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/>
                    <path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/>
                  </svg>
                  Editar
                </button>
                <form action="/review/delete" method="POST" class="resena-delete-form">
                  <input type="hidden" name="csrf_token" value="{{ csrf_token }}">
                  <input type="hidden" name="review_id" value="{{ review.id }}">
                  <input type="hidden" name="tmdb_id" value="{{ review.tmdb_id }}">
                  <input type="hidden" name="redirect" value="/my-reviews">
                  <button type="button" class="btn-eliminar-resenia" data-id="{{ review.id }}">
                    <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24"
                      fill="none" stroke="currentColor" stroke-width="2"
                      stroke-linecap="round" stroke-linejoin="round">
                      <polyline points="3 6 5 6 21 6"/>
                      <path d="M19 6l-1 14a2 2 0 0 1-2 2H8a2 2 0 0 1-2-2L5 6"/>
                      <path d="M10 11v6M14 11v6"/>
                      <path d="M9 6V4a1 1 0 0 1 1-1h4a1 1 0 0 1 1 1v2"/>
                    </svg>
                    Eliminar
                  </button>
                </form>
              </div>
            </div>
            <p class="resenia-card__texto">{{ review.body|default('') }}</p>
            <time class="resenia-card__fecha">{{ review.created_at|date('d M Y') }}</time>
          </div>

          <div class="resena-form-wrap" id="editarResenaWrap{{ review.id }}">
            <form class="resena-form" action="/review/update" method="POST">
              <input type="hidden" name="csrf_token" value="{{ csrf_token }}">
              <input type="hidden" name="review_id" value="{{ review.id }}">
              <input type="hidden" name="tmdb_id" value="{{ review.tmdb_id }}">
              <input type="hidden" name="redirect" value="/my-reviews">
              <div class="resena-form__stars" role="group" aria-label="Puntuación">
                {% for i in range(5, 1) %}
                  <input type="radio" id="editStar{{ review.id }}_{{ i }}" name="score" value="{{ i }}"
                    class="star-input" {{ review.score == i ? 'checked' : '' }}>
                  <label for="editStar{{ review.id }}_{{ i }}" class="star-label">★</label>
                {% endfor %}
              </div>
              <textarea class="resena-form__textarea" name="review_body" rows="4" maxlength="1000">{{ review.body|default('') }}</textarea>
              <div class="resena-form__actions">
                <button type="button" class="btn-cancelar" data-id="{{ review.id }}">Cancelar</button>
                <button type="submit" class="btn-publicar">Guardar cambios</button>
              </div>
            </form>
          </div>

        </article>
      {% endfor %}
    {% endif %}
  </section>

  {% for review in reviews %}
    <div class="modal-overlay" id="modalEliminar{{ review.id }}">
      <div class="modal">
        <p class="modal__texto">¿Seguro que querés eliminar tu reseña de <strong>{{ review.title }}</strong>?</p>
        <div class="modal__actions">
          <button class="btn-cancelar" data-modal-id="{{ review.id }}">Cancelar</button>
          <button class="btn-eliminar-resenia" data-confirm-id="{{ review.id }}">Sí, eliminar</button>
        </div>
      </div>
    </div>
  {% endfor %}

  {% if flashSuccess %}
    <div class="toast toast--success" id="toast" role="alert">
      <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24"
           fill="none" stroke="currentColor" stroke-width="2"
           stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/>
        <polyline points="22 4 12 14.01 9 11.01"/>
      </svg>
      {{ flashSuccess }}
    </div>
  {% endif %}

  {% if flashError %}
    <div class="toast toast--error" id="toast" role="alert">
      <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24"
           fill="none" stroke="currentColor" stroke-width="2"
           stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <circle cx="12" cy="12" r="10"/>
        <line x1="12" y1="8" x2="12" y2="12"/>
        <line x1="12" y1="16" x2="12.01" y2="16"/>
      </svg>
      {{ flashError }}
    </div>
  {% endif %}

{% endblock %}
{% block scripts %}
  <script type="module" src="/assets/js/pages/MyReviews.js"></script>
{% endblock %}