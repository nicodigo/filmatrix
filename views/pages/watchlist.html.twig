{% extends 'layout/main.html.twig' %}
{% import 'macros/title-cards.html.twig' as cards %}

{% block title %}Mi Watchlist — Filmatrix{% endblock %}

{% block description %}Gestioná tu watchlist personal en Filmatrix.{% endblock %}
{% block robots %}noindex, nofollow{% endblock %}

{% block styles %}
  <link rel="stylesheet" href="/assets/css/watchlist.css">
  <link rel="stylesheet" href="/assets/css/movie-card.css">
{% endblock %}

{% block content %}
  <header class="watchlist-header">
    <h1 class="watchlist-title">Mi Watchlist</h1>
  </header>

  <nav class="watchlist-filters" aria-label="Filtros de watchlist">
    <ul class="watchlist-filters__list">
      <li>
        <a href="/my-watchlist"
           class="watchlist-filter{% if pagination.status is null %} watchlist-filter--active{% endif %}">
          Todas
        </a>
      </li>
      <li>
        <a href="/my-watchlist?status=pending"
           class="watchlist-filter{% if pagination.status == 'pending' %} watchlist-filter--active{% endif %}">
          Pendientes
        </a>
      </li>
      <li>
        <a href="/my-watchlist?status=watched"
           class="watchlist-filter{% if pagination.status == 'watched' %} watchlist-filter--active{% endif %}">
          Vistas
        </a>
      </li>
    </ul>
  </nav>

  <section class="watchlist-content">
    {% for item in items %}
      {{ cards.titleCard(item, { showScore: false }) }}
    {% else %}
      <p class="watchlist-empty">
        {% if pagination.status == 'pending' %}
          No tenés títulos pendientes.
        {% elseif pagination.status == 'watched' %}
          No tenés títulos vistos aún.
        {% else %}
          Tu watchlist está vacía.
        {% endif %}
      </p>
    {% endfor %}
  </section>

  {% if pagination.totalPages > 1 %}
    <nav class="watchlist-pagination" aria-label="Paginación de watchlist">
      {% if prevUrl %}
        <a href="{{ prevUrl }}" class="watchlist-pagination__btn" rel="prev">
          Anterior
        </a>
      {% else %}
        <span class="watchlist-pagination__btn watchlist-pagination__btn--disabled">
          Anterior
        </span>
      {% endif %}

      <span class="watchlist-pagination__info">
        Página {{ pagination.currentPage }} de {{ pagination.totalPages }}
      </span>

      {% if nextUrl %}
        <a href="{{ nextUrl }}" class="watchlist-pagination__btn" rel="next">
          Siguiente
        </a>
      {% else %}
        <span class="watchlist-pagination__btn watchlist-pagination__btn--disabled">
          Siguiente
        </span>
      {% endif %}
    </nav>
  {% endif %}
{% endblock %}
